{
    "name": "@reversi/gui",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "bin": {
        "reversi-gui": "./dist/bin/app.js"
    },
    "scripts": {
        "build": "node scripts/clean-dist.mjs && tsc && vite build",
        "start": "pnpm run gui",
        "gui": "pnpm run build && env -u ELECTRON_RUN_AS_NODE electron dist/bin/app.js",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "test": "node --test dist/**/*.test.js",
        "ci": "pnpm run format:check && pnpm run build && pnpm test"
    },
    "dependencies": {
        "@reversi/core": "workspace:*"
    },
    "devDependencies": {
        "@types/node": "^24.0.0",
        "electron": "^42.0.1",
        "prettier": "3.8.3",
        "typescript": "^5.8.0",
        "vite": "^7.0.0"
    }
}
