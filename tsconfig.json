{
    "compilerOptions": {
        "target": "ES2022",
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "strict": true,
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "rewriteRelativeImportExtensions": true,
        "types": ["node"],
        "skipLibCheck": true,
        "outDir": "dist",
        "rootDir": "."
    },
    "include": ["bin/**/*.ts", "lib/**/*.ts"]
}
