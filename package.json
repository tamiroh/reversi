{
    "name": "reversi-cli",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "bin": {
        "reversi": "./dist/bin/reversi.js"
    },
    "scripts": {
        "build": "tsc",
        "start": "node dist/bin/reversi.js",
        "dev": "node bin/reversi.ts",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "test": "node --test dist/**/*.test.js",
        "ci": "npm run format:check && npm run build && npm test"
    },
    "devDependencies": {
        "@types/node": "^24.0.0",
        "prettier": "3.8.3",
        "typescript": "^5.8.0"
    }
}
